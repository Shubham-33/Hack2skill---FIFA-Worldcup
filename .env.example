# GateReady — environment template
# Copy to .env (local) and .env.local (inside web/ for Next.js). Never commit either.
# Both are covered by .gitignore.

# ─────────────────────────────────────────────────────────────
# Tier 1 — Gemini (primary LLM: vision + text)
# Free, no billing card: https://aistudio.google.com/apikey
# Model: gemini-2.5-flash  (Pro is paid-only as of Apr 2026)
# ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=

# ─────────────────────────────────────────────────────────────
# Tier 2 — NVIDIA NIM (failover on Gemini 429/5xx)
# Free: https://build.nvidia.com  — key starts with nvapi-
# OpenAI-compatible: https://integrate.api.nvidia.com/v1/chat/completions
# VERIFIED 2026-07-18: llama-3.3-70b-instruct and llama-4-maverick HANG on this account
# (GET /v1/models 200 in 58ms, but POST /chat/completions never returns).
# llama-3.2-90b-vision-instruct responds in ~1.2s AND is multimodal, so tier 2
# handles photos too — failover no longer degrades the core demo.
# Other verified-working: nvidia/nemotron-nano-12b-v2-vl (0.4s), meta/llama-3.1-8b-instruct (0.3s)
# ─────────────────────────────────────────────────────────────
NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.2-90b-vision-instruct

# ─────────────────────────────────────────────────────────────
# Tier 3 — deterministic Sheet lookup. No key required by design.
# This is why the test suite runs without any credentials.
# ─────────────────────────────────────────────────────────────

# ─────────────────────────────────────────────────────────────
# Google Sheets (policy database + question log)
# Service account, read-only on policies/venues, append-only on questions_log.
# Paste the service-account JSON as a single line, or point to a local file.
# ─────────────────────────────────────────────────────────────
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=
# Local-dev alternative to the above (gitignored, never deployed):
# GOOGLE_APPLICATION_CREDENTIALS=credentials.json

# ─────────────────────────────────────────────────────────────
# No keys needed below — URL-spec dispatch, zero auth by design
#   Calendar: calendar.google.com/calendar/render?action=TEMPLATE&...
#   Maps:     google.com/maps/dir/?api=1&destination=...
#   Fonts:    fonts.googleapis.com
# Do NOT add Maps Platform JS SDK — it requires a billing card.
# ─────────────────────────────────────────────────────────────
